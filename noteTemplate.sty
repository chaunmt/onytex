% ---------- DIAGRAM ----------
% Decode Presets
\def\DecodeOriginal{0 1  0 1  0 1}            % Original
\def\DecodeInvert{1 0  1 0  1 0}            % Full invert
\def\DecodeDark{0.95 0  0.95 0  0.95 0}     % Invert with less contrast

% #1=panel color #2=decode macro #3=width #4=caption #5=image path 
\newcommand{\diagram}[5]{
    \par\medskip 
    {%
        \centering
        \ifx #1 \empty
            \includegraphics[width=#3\linewidth, decodearray={#2}]{#5}%
        \else
            \colorbox{#1}{%
                \includegraphics[width=#3\linewidth, decodearray={#2}]{#5}%
            }%
        \fi
        \par
        \captionof{figure}{#4}
        \label{fig:\thefigure}
    }% 
    \par\medskip
}

\newcommand{\LabelFromCaption}[1]{%
  \StrRemoveAll{#1}{ }[\TmpLabel]%
  fig:\TmpLabel%
}

\newcommand{\diagramBase}[3]{
    \diagram{ }{\DecodeOriginal}{#1}{#2}{#3}
}

\newcommand{\diagramWhite}[3]{
    \diagram{white}{\DecodeOriginal}{#1}{#2}{#3}
}

\newcommand{\diagramInvert}[3]{
    \diagram{black}{\DecodeInvert}{#1}{#2}{#3}
}

\newcommand{\diagramDark}[3]{
    \diagram{black}{\DecodeDark}{#1}{#2}{#3}
}

% ---------- COLOR BOX ----------

% Base Style
\tcbset{
  colorBase/.style={
    enhanced,
    frame hidden,
    colback=PageDarkBG,
    coltext=.,
    boxrule=0pt,
    arc=4pt,
    outer arc=4pt,
  },
  colorInline/.style={
    colorBase,
    on line,
    boxsep=3pt,
    left=6pt,
    right=6pt,
    top=4pt,
    bottom=4pt,
  },
  colorBlock/.style={
    colorBase,
    boxsep=6pt,
    left=8pt,
    right=8pt,
    top=6pt,
    bottom=6pt,
  }
}

% Inline Helper
\newcommand{\colorBox}[4]{%
  \IfStrEq{#3}{dash}{%
    \tcbox[
      colorInline,
      borderline={#2}{0pt}{#1,dash pattern=on 4pt off 3pt}
    ]{#4}%
  }{%
    \tcbox[
      colorInline,
      borderline={#2}{0pt}{#1}
    ]{#4}%
  }%
}

% Block Helper
\newcommand{\cbStartBlock}[3]{%
  \IfStrEq{#3}{dash}{%
    \tcolorbox[
      colorBlock,
      borderline={#2}{0pt}{#1,dash pattern=on 4pt off 3pt}
    ]%
  }{%
    \tcolorbox[
      colorBlock,
      borderline={#2}{0pt}{#1}
    ]%
  }%
}

% Thickness helpers
\newcommand{\cbLight}{1pt}
\newcommand{\cbRegular}{1.6pt}
\newcommand{\cbBold}{2.4pt}

% Inline generator
\newcommand{\defineColorBoxes}[2]{%
  % #1 = Name (Blue)
  % #2 = Color (EmphBlue)

  % Solid
  \expandafter\newcommand\csname box#1SolidLight\endcsname[1]{%
    \colorBox{#2}{\cbLight}{solid}{##1}%
  }
  \expandafter\newcommand\csname box#1SolidRegular\endcsname[1]{%
    \colorBox{#2}{\cbRegular}{solid}{##1}%
  }
  \expandafter\newcommand\csname box#1SolidBold\endcsname[1]{%
    \colorBox{#2}{\cbBold}{solid}{##1}%
  }

  % Dash
  \expandafter\newcommand\csname box#1DashLight\endcsname[1]{%
    \colorBox{#2}{\cbLight}{dash}{##1}%
  }
  \expandafter\newcommand\csname box#1DashRegular\endcsname[1]{%
    \colorBox{#2}{\cbRegular}{dash}{##1}%
  }
  \expandafter\newcommand\csname box#1DashBold\endcsname[1]{%
    \colorBox{#2}{\cbBold}{dash}{##1}%
  }
}

% Block Generator
\newcommand{\defineColorBlocks}[2]{%
  % #1 = Name (Blue)
  % #2 = Color (EmphBlue)

  % Solid
  \expandafter\def\csname block#1SolidLight\endcsname{%
    \cbStartBlock{#2}{\cbLight}{solid}%
  }
  \expandafter\def\csname endblock#1SolidLight\endcsname{%
    \endtcolorbox
  }

  \expandafter\def\csname block#1SolidRegular\endcsname{%
    \cbStartBlock{#2}{\cbRegular}{solid}%
  }
  \expandafter\def\csname endblock#1SolidRegular\endcsname{%
    \endtcolorbox
  }

  \expandafter\def\csname block#1SolidBold\endcsname{%
    \cbStartBlock{#2}{\cbBold}{solid}%
  }
  \expandafter\def\csname endblock#1SolidBold\endcsname{%
    \endtcolorbox
  }

  % Dash
  \expandafter\def\csname block#1DashLight\endcsname{%
    \cbStartBlock{#2}{\cbLight}{dash}%
  }
  \expandafter\def\csname endblock#1DashLight\endcsname{%
    \endtcolorbox
  }

  \expandafter\def\csname block#1DashRegular\endcsname{%
    \cbStartBlock{#2}{\cbRegular}{dash}%
  }
  \expandafter\def\csname endblock#1DashRegular\endcsname{%
    \endtcolorbox
  }

  \expandafter\def\csname block#1DashBold\endcsname{%
    \cbStartBlock{#2}{\cbBold}{dash}%
  }
  \expandafter\def\csname endblock#1DashBold\endcsname{%
    \endtcolorbox
  }
}

